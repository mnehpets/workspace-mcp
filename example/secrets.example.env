# secrets.example.env — copy to secrets.env (gitignored) and set real values.
# The bearer token must be at least 32 random bytes. Generate one with:
#   openssl rand -hex 32
MCP_BEARER_TOKEN=replace-with-a-long-random-token-at-least-32-bytes
# During rotation, set a second token and list both under auth.bearerTokens in
# config.yaml; the server accepts either until you drop the old one.
# MCP_BEARER_TOKEN_NEXT=replace-with-another-long-random-token

# ngrok authtoken — required when server.ngrok.enabled is true in config.yaml.
# Find yours at https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=replace-with-your-ngrok-authtoken

# zrok account token — required when server.zrok.enabled is true in config.yaml
# (enable at most one of ngrok/zrok; each replaces the local listener). This is
# the `zrok enable` token from your account, never stored in the YAML.
ZROK_ENABLE_TOKEN=replace-with-your-zrok-enable-token

# OAuth client secret — required when auth.oauth is configured in config.yaml.
# Generate a strong random value: openssl rand -hex 32
OAUTH_CLIENT_SECRET=replace-with-a-strong-random-secret
